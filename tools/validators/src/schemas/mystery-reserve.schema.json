{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldloom.local/schemas/mystery-reserve.schema.json",
  "title": "MysteryReserveEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "status", "knowns", "unknowns", "common_interpretations", "disallowed_cheap_answers", "domains_touched", "future_resolution_safety", "extensions"],
  "properties": {
    "id": { "type": "string", "pattern": "^M-[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "passive", "passive_depth", "forbidden"] },
    "knowns": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "unknowns": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "common_interpretations": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["description", "holders"],
            "properties": {
              "description": { "type": "string", "minLength": 1 },
              "holders": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "disallowed_cheap_answers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "domains_touched": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "future_resolution_safety": { "type": "string", "minLength": 1 },
    "extensions": { "type": "array", "items": { "$ref": "https://worldloom.local/schemas/extension-entry.schema.json" } }
  }
}
