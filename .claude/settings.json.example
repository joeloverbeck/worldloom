{
  "_comment": "Worldloom hook configuration example. Copy or merge into .claude/settings.json. All five hooks are active as of SPEC-05 Part B (Phase 2). Each hook's implementation lives at tools/hooks/dist/src/*.js, built from tools/hooks/src/*.ts (see archive/specs/SPEC-05-hooks-discipline.md).",

  "hooks": {
    "UserPromptSubmit": [
      {
        "_phase": 1,
        "_spec": "SPEC-05 Hook 1",
        "_purpose": "Inject context preface: world slug, top relevant node ids, named entities, size warnings",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/hooks/dist/src/hook1-user-prompt-context.js"
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "_phase": 1,
        "_spec": "SPEC-05 Hook 2",
        "_purpose": "Block full Read of CANON_LEDGER.md (always) and other protected files when >300 lines; redirect to mcp__worldloom__get_context_packet",
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/hooks/dist/src/hook2-guard-large-read.js"
          }
        ]
      },
      {
        "_phase": 2,
        "_spec": "SPEC-05 Hook 3",
        "_purpose": "Block direct Edit/Write on engine-only _source/*.yaml records; allow WORLD_KERNEL.md, ONTOLOGY.md, _source/<subdir>/README.md, and hybrid artifacts (characters/, diegetic-artifacts/, adjudications/, proposals/, audits/). Redirect to mcp__worldloom__submit_patch_plan.",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/hooks/dist/src/hook3-guard-direct-edit.js"
          }
        ]
      }
    ],

    "SubagentStart": [
      {
        "_phase": 1,
        "_spec": "SPEC-05 Hook 4",
        "_purpose": "Bootstrap localization sub-agents with retrieval discipline (exact ids > entity names > heading paths > backlinks > lexical; no semantic-only)",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/hooks/dist/src/hook4-subagent-localization.js"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "_phase": 2,
        "_spec": "SPEC-05 Hook 5",
        "_purpose": "Auto-run structural validators (record_schema_compliance, id_uniqueness, cross_file_reference, touched_by_cf_completeness) after successful submit_patch_plan; log and surface fails via system reminder.",
        "matcher": "mcp__worldloom__submit_patch_plan",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/hooks/dist/src/hook5-validate-after-patch.js"
          }
        ]
      }
    ]
  }
}
